# 建议在 deploy 目录下复制为 .env 后再启动：
# cp .env.example .env

COMPOSE_PROJECT_NAME=pulsix
TZ=Asia/Shanghai

# MySQL
MYSQL_PORT=3306
MYSQL_DATABASE=pulsix
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_USER=pulsix
MYSQL_PASSWORD=change_me_app

# Redis（留空表示不启用密码）
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka（宿主机通过 localhost:${KAFKA_PORT} 访问；容器内通过 kafka:9092 访问）
KAFKA_PORT=29092
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# Flink
FLINK_JOBMANAGER_PORT=8081
FLINK_TASK_SLOTS=2
FLINK_PARALLELISM=2

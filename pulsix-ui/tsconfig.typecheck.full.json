{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "vueCompilerOptions": {
    "strictTemplates": false
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "types/**/*.d.ts",
    "src/types/**/*.d.ts"
  ],
  "exclude": ["dist", "target", "node_modules"]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneSnapshot",
  "description": "场景发布后唯一可执行的运行时快照契约。Flink、仿真、回放只能消费该对象。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "snapshotId",
    "sceneCode",
    "version",
    "checksum",
    "publishedAt",
    "effectiveFrom",
    "scene",
    "streamFeatures",
    "lookupFeatures",
    "derivedFeatures",
    "rules",
    "policy",
    "runtimeHints"
  ],
  "properties": {
    "snapshotId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "快照唯一标识。建议采用 sceneCode_v{version} 形式。"
    },
    "sceneCode": {
      "$ref": "#/$defs/sceneCode",
      "description": "快照所属场景编码。"
    },
    "sceneName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "场景名称，仅用于展示与日志。"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "场景发布版本号。单条事件进入链路后必须绑定此版本执行到底。"
    },
    "checksum": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{8,128}$",
      "description": "快照校验和，用于幂等、乱序判断和一致性校验。"
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time",
      "description": "发布时间。"
    },
    "effectiveFrom": {
      "type": "string",
      "format": "date-time",
      "description": "开始生效时间。"
    },
    "scene": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowedEventTypes"
      ],
      "properties": {
        "defaultPolicyCode": {
          "$ref": "#/$defs/policyCode"
        },
        "allowedEventTypes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/eventType"
          }
        },
        "decisionTimeoutMs": {
          "type": "integer",
          "minimum": 1
        },
        "logLevel": {
          "type": "string",
          "enum": [
            "BASIC",
            "FULL"
          ]
        },
        "ext": {
          "$ref": "#/$defs/extObject"
        }
      }
    },
    "eventSchema": {
      "type": "object",
      "description": "可选的场景级事件校验元信息，主要服务控制面仿真与接入标准化。",
      "additionalProperties": false,
      "required": [
        "eventType",
        "requiredFields"
      ],
      "properties": {
        "eventCode": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "eventType": {
          "$ref": "#/$defs/eventType"
        },
        "requiredFields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "uniqueItems": true
        },
        "optionalFields": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "uniqueItems": true
        },
        "ext": {
          "$ref": "#/$defs/extObject"
        }
      }
    },
    "variables": {
      "type": "object",
      "description": "可选的运行时变量目录，主要帮助编译期校验与仿真展示。",
      "additionalProperties": false,
      "properties": {
        "baseFields": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        },
        "ext": {
          "$ref": "#/$defs/extObject"
        }
      }
    },
    "streamFeatures": {
      "type": "array",
      "description": "由 Flink State 维护的流式特征定义。",
      "items": {
        "$ref": "#/$defs/streamFeature"
      },
      "uniqueItems": true
    },
    "lookupFeatures": {
      "type": "array",
      "description": "由受控在线存储提供的 lookup 特征定义。",
      "items": {
        "$ref": "#/$defs/lookupFeature"
      },
      "uniqueItems": true
    },
    "derivedFeatures": {
      "type": "array",
      "description": "由表达式或受控 Groovy 计算的派生特征定义。",
      "items": {
        "$ref": "#/$defs/derivedFeature"
      },
      "uniqueItems": true
    },
    "rules": {
      "type": "array",
      "description": "已通过发布校验并可直接执行的规则定义。",
      "items": {
        "$ref": "#/$defs/ruleSpec"
      },
      "uniqueItems": true
    },
    "policy": {
      "$ref": "#/$defs/policySpec"
    },
    "runtimeHints": {
      "$ref": "#/$defs/runtimeHints"
    },
    "ext": {
      "$ref": "#/$defs/extObject",
      "description": "保留给不会改变运行时主语义的附加元信息。"
    }
  },
  "$defs": {
    "sceneCode": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "eventType": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_:-]*$",
      "maxLength": 64
    },
    "featureCode": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "maxLength": 128
    },
    "ruleCode": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$",
      "maxLength": 128
    },
    "policyCode": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$",
      "maxLength": 128
    },
    "actionType": {
      "type": "string",
      "enum": [
        "PASS",
        "REVIEW",
        "REJECT"
      ]
    },
    "engineType": {
      "type": "string",
      "enum": [
        "AVIATOR",
        "GROOVY"
      ]
    },
    "entityType": {
      "type": "string",
      "enum": [
        "USER",
        "DEVICE",
        "IP",
        "ACCOUNT"
      ]
    },
    "aggType": {
      "type": "string",
      "enum": [
        "COUNT",
        "SUM",
        "MAX",
        "LATEST",
        "DISTINCT_COUNT"
      ]
    },
    "lookupType": {
      "type": "string",
      "enum": [
        "REDIS_SET",
        "REDIS_HASH"
      ]
    },
    "valueType": {
      "type": "string",
      "enum": [
        "BOOLEAN",
        "STRING",
        "INT",
        "LONG",
        "DECIMAL",
        "DOUBLE"
      ]
    },
    "durationToken": {
      "type": "string",
      "pattern": "^[1-9][0-9]*(ms|s|m|h|d)$"
    },
    "extObject": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/jsonValue"
      }
    },
    "scoreBand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min",
        "max",
        "action"
      ],
      "properties": {
        "min": {
          "type": "integer"
        },
        "max": {
          "type": "integer"
        },
        "action": {
          "$ref": "#/$defs/actionType"
        }
      }
    },
    "streamFeature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "sourceEventTypes",
        "entityType",
        "entityKeyExpr",
        "aggType",
        "valueExpr",
        "windowType",
        "windowSize",
        "ttl",
        "valueType"
      ],
      "properties": {
        "code": {
          "$ref": "#/$defs/featureCode"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "sourceEventTypes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/eventType"
          }
        },
        "entityType": {
          "$ref": "#/$defs/entityType"
        },
        "entityKeyExpr": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "aggType": {
          "$ref": "#/$defs/aggType"
        },
        "valueExpr": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "filterExpr": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "windowType": {
          "type": "string",
          "enum": [
            "SLIDING",
            "TUMBLING"
          ]
        },
        "windowSize": {
          "$ref": "#/$defs/durationToken"
        },
        "windowSlide": {
          "$ref": "#/$defs/durationToken"
        },
        "includeCurrentEvent": {
          "type": "boolean"
        },
        "ttl": {
          "$ref": "#/$defs/durationToken"
        },
        "valueType": {
          "$ref": "#/$defs/valueType"
        },
        "ext": {
          "$ref": "#/$defs/extObject"
        }
      }
    },
    "lookupFeature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "lookupType",
        "keyExpr",
        "sourceRef",
        "defaultValue",
        "valueType"
      ],
      "properties": {
        "code": {
          "$ref": "#/$defs/featureCode"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "lookupType": {
          "$ref": "#/$defs/lookupType"
        },
        "keyExpr": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "sourceRef": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "defaultValue": {
          "$ref": "#/$defs/jsonValue"
        },
        "valueType": {
          "$ref": "#/$defs/valueType"
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1
        },
        "cacheTtlSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "ext": {
          "$ref": "#/$defs/extObject"
        }
      }
    },
    "derivedFeature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "engineType",
        "expr",
        "dependsOn",
        "valueType"
      ],
      "properties": {
        "code": {
          "$ref": "#/$defs/featureCode"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "engineType": {
          "$ref": "#/$defs/engineType"
        },
        "expr": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "uniqueItems": true
        },
        "valueType": {
          "$ref": "#/$defs/valueType"
        },
        "ext": {
          "$ref": "#/$defs/extObject"
        }
      }
    },
    "ruleSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "engineType",
        "priority",
        "whenExpr",
        "dependsOn",
        "hitAction"
      ],
      "properties": {
        "code": {
          "$ref": "#/$defs/ruleCode"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "engineType": {
          "$ref": "#/$defs/engineType"
        },
        "priority": {
          "type": "integer",
          "minimum": 0
        },
        "whenExpr": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "uniqueItems": true
        },
        "hitAction": {
          "$ref": "#/$defs/actionType"
        },
        "riskScore": {
          "type": "integer"
        },
        "hitReasonTemplate": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "ext": {
          "$ref": "#/$defs/extObject"
        }
      }
    },
    "policySpec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policyCode",
        "decisionMode",
        "defaultAction",
        "ruleOrder"
      ],
      "properties": {
        "policyCode": {
          "$ref": "#/$defs/policyCode"
        },
        "policyName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "decisionMode": {
          "type": "string",
          "enum": [
            "FIRST_HIT",
            "SCORE_CARD"
          ]
        },
        "defaultAction": {
          "$ref": "#/$defs/actionType"
        },
        "ruleOrder": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ruleCode"
          },
          "uniqueItems": true
        },
        "scoreBands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/scoreBand"
          }
        },
        "ext": {
          "$ref": "#/$defs/extObject"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "decisionMode": {
                "const": "SCORE_CARD"
              }
            }
          },
          "then": {
            "required": [
              "scoreBands"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "decisionMode": {
                "const": "FIRST_HIT"
              }
            }
          },
          "then": {
            "not": {
              "required": [
                "scoreBands"
              ]
            }
          }
        }
      ]
    },
    "runtimeHints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requiredStreamFeatures",
        "requiredLookupFeatures",
        "requiredDerivedFeatures"
      ],
      "properties": {
        "requiredStreamFeatures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/featureCode"
          },
          "uniqueItems": true
        },
        "requiredLookupFeatures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/featureCode"
          },
          "uniqueItems": true
        },
        "requiredDerivedFeatures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/featureCode"
          },
          "uniqueItems": true
        },
        "maxRuleExecutionCount": {
          "type": "integer",
          "minimum": 1
        },
        "allowGroovy": {
          "type": "boolean"
        },
        "needFullDecisionLog": {
          "type": "boolean"
        },
        "ext": {
          "$ref": "#/$defs/extObject"
        }
      }
    },
    "jsonValue": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        }
      ]
    }
  }
}

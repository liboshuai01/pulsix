{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RiskEvent",
  "description": "统一运行时事件模型。控制面仿真、Flink 执行、日志追溯都基于同一事件包络。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "traceId",
    "sceneCode",
    "eventType",
    "eventTime",
    "entity",
    "payload",
    "ext"
  ],
  "properties": {
    "eventId": {
      "$ref": "#/$defs/idString",
      "description": "事件唯一标识。用于幂等、回放、日志追溯。"
    },
    "traceId": {
      "$ref": "#/$defs/idString",
      "description": "链路追踪标识。一次业务链路内的多事件可共享。"
    },
    "sceneCode": {
      "$ref": "#/$defs/sceneCode",
      "description": "事件归属风控场景编码，例如 TRADE_RISK。"
    },
    "eventType": {
      "$ref": "#/$defs/eventType",
      "description": "事件类型，例如 trade、login、register。"
    },
    "eventTime": {
      "type": "string",
      "format": "date-time",
      "description": "事件业务发生时间，统一使用 ISO-8601。"
    },
    "entity": {
      "type": "object",
      "description": "标准化实体字段。一期固定 user/device/ip/account 四类实体键。",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "userId": {
          "$ref": "#/$defs/idString"
        },
        "deviceId": {
          "$ref": "#/$defs/idString"
        },
        "ip": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "accountId": {
          "$ref": "#/$defs/idString"
        }
      }
    },
    "payload": {
      "type": "object",
      "description": "标准化后的业务字段载荷。引擎会将其映射到 EvalContext.base。",
      "additionalProperties": {
        "$ref": "#/$defs/jsonValue"
      }
    },
    "ext": {
      "$ref": "#/$defs/extObject",
      "description": "额外扩展字段。仅允许放不会改变主链路语义的补充信息。"
    }
  },
  "$defs": {
    "idString": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "sceneCode": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "eventType": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_:-]*$",
      "maxLength": 64
    },
    "extObject": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/jsonValue"
      }
    },
    "jsonValue": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        }
      ]
    }
  }
}
